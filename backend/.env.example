# Copy to backend/.env for local `npm run start:dev` (optional; docker uses repo root `.env`)

NODE_ENV=development
PORT=3001

# Option A: single URL
DATABASE_URL=postgresql://noir_admin:noir_password_2026@localhost:5432/noir_ride

# Option B: discrete vars (used if DATABASE_URL is unset or invalid)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=noir_admin
DB_PASSWORD=noir_password_2026
DB_DATABASE=noir_ride

JWT_SECRET=dev_change_me_use_long_random_string
FRONTEND_URL=http://localhost:3000

# Auto schema in dev; never leave true in production after first migrate
DB_SYNC=false
