# Docker Compose reads this file from the repo root for ${VAR} substitution
# (same file is mounted into backend/migrate when present). Keep DB_* in sync
# with DATABASE_URL if you use both.

# --- PostgreSQL (docker service name: db) ---
DB_USERNAME=noir_admin
DB_PASSWORD=change_this_to_a_long_random_secret
DB_DATABASE=noir_ride

# TypeORM (recommended in Docker; host must be `db`)
DATABASE_URL=postgresql://noir_admin:change_this_to_a_long_random_secret@db:5432/noir_ride

# --- NestJS backend ---
NODE_ENV=production
PORT=3000
JWT_SECRET=change_this_to_at_least_32_random_bytes_base64_or_string
FRONTEND_URL=https://noir-ride.ru

# First deploy on empty DB: true once, then set false (or use migrations only)
DB_SYNC=true

# --- Next.js (build-time; also used by compose build-args) ---
NEXT_PUBLIC_API_URL=https://noir-ride.ru/api
